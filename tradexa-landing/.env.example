# Tradexa Trading Bot — landing + auth environment
#
# Supabase powers authentication. The anon (public) key is designed to be
# exposed in the browser — it is safe to commit to your deploy provider's env.
# Leave these blank to run the auth UI in DEMO mode (forms validate and animate,
# but no real account is created).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Where the "Launch Bot" CTA and post-login redirect send the user (the running
# Automation Hub dashboard). Defaults to "/app" if unset.
VITE_APP_URL=
